<?xml version="1.0"?>
<robot name="warehouse_car" xmlns:xacro="http://www.ros.org/wiki/xacro">

  <!-- ==================== MATERIALS ==================== -->
  <material name="chassis"> <color rgba="0.8 0.8 0.8 1"/> </material>
  <material name="wheel">   <color rgba=".7 .1 .1 1"/>   </material>
  <material name="caster">  <color rgba=".5 .5 .5 .9"/>  </material>
  <material name="sensor">  <color rgba="0 0 0 1"/>       </material>
  <material name="robot">   <color rgba="0 0 0 1"/>       </material>

  <!-- ==================== PARAMETERS ==================== -->
  <xacro:property name="wheel_radius"    value="0.06"/>
  <xacro:property name="wheel_width"     value="0.05"/>
  <xacro:property name="wheel_separation" value=".356"/>
  <xacro:property name="wheel_density"   value="417"/>
  <xacro:property name="wheel_volume"    value="${3.14*wheel_radius*wheel_radius*wheel_width}"/>
  <xacro:property name="wheel_mass"      value="${wheel_density*wheel_volume}"/>

  <xacro:property name="chassis_length"  value="0.6"/>
  <xacro:property name="chassis_width"   value="0.4"/>
  <xacro:property name="chassis_height"  value="0.2"/>
  <xacro:property name="chassis_density" value="955"/>
  <xacro:property name="chassis_volume"  value="${chassis_length*chassis_width*chassis_height}"/>
  <xacro:property name="chassis_mass"    value="${chassis_density*chassis_volume}"/>

  <xacro:property name="caster_radius"   value=".027"/>
  <xacro:property name="caster_mass"     value=".3"/>

  <!-- ==================== INERTIA MACROS ==================== -->
  <xacro:macro name="box_inertia" params="m x y z o_xyz o_rpy">
    <inertial>
      <mass value="${m}"/>
      <origin xyz="${o_xyz}" rpy="${o_rpy}"/>
      <inertia ixx="${(m/12)*(z*z+y*y)}" ixy="0" ixz="0"
               iyy="${(m/12)*(x*x+z*z)}" iyz="0"
               izz="${(m/12)*(x*x+y*y)}"/>
    </inertial>
  </xacro:macro>

  <xacro:macro name="cylinder_inertia" params="m r l o_xyz o_rpy">
    <inertial>
      <mass value="${m}"/>
      <origin xyz="${o_xyz}" rpy="${o_rpy}"/>
      <inertia ixx="${(m/12)*(3*r*r+l*l)}" ixy="0" ixz="0"
               iyy="${(m/12)*(3*r*r+l*l)}" iyz="0"
               izz="${(m/2)*(r*r)}"/>
    </inertial>
  </xacro:macro>

  <xacro:macro name="sphere_inertia" params="m r o_xyz o_rpy">
    <inertial>
      <mass value="${m}"/>
      <origin xyz="${o_xyz}" rpy="${o_rpy}"/>
      <inertia ixx="${(2/5)*m*r*r}" ixy="0" ixz="0"
               iyy="${(2/5)*m*r*r}" iyz="0"
               izz="${(2/5)*m*r*r}"/>
    </inertial>
  </xacro:macro>

  <!-- ==================== BASE LINK ==================== -->
  <link name="base_link"/>

  <!-- ==================== ROBOT BODY ==================== -->
  <link name="robot_body">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 -1.57"/>
      <geometry>
        <mesh filename="package://warehouse_system/mesh/robot_body_modified.dae"/>
      </geometry>
    </visual>
    <collision>
      <origin xyz="0 0 .68" rpy="0 0 0"/>
      <geometry>
        <box size="${chassis_length} ${chassis_width} 1.3"/>
      </geometry>
    </collision>
    <xacro:box_inertia m="100" x="${chassis_length}" y="${chassis_width}" z="${chassis_height}"
                       o_xyz="0 0 ${chassis_height/2}" o_rpy="0 0 0"/>
  </link>

  <joint name="base_to_chassis" type="fixed">
    <parent link="base_link"/>
    <child link="robot_body"/>
    <origin xyz="0 0 ${wheel_radius}" rpy="0 0 0"/>
  </joint>

  <!-- ==================== ROBOT HEAD ==================== -->
  <link name="robot_head">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 -1.57"/>
      <geometry>
        <mesh filename="package://warehouse_system/mesh/robot_head_modified.dae"/>
      </geometry>
    </visual>
    <inertial>
      <mass value="0.08"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="0.01" ixy="0" ixz="0" iyy="0.01" iyz="0" izz="0.01"/>
    </inertial>
  </link>

  <joint name="robot_head_joint" type="fixed">
    <parent link="robot_body"/>
    <child link="robot_head"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <!-- ==================== ARMS ==================== -->
  <link name="right_arm">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 -1.57"/>
      <geometry>
        <mesh filename="package://warehouse_system/mesh/right_arm_modified.dae"/>
      </geometry>
    </visual>
    <inertial>
      <mass value="0.1"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="0.01" ixy="0" ixz="0" iyy="0.01" iyz="0" izz="0.01"/>
    </inertial>
  </link>

  <joint name="right_arm_joint" type="fixed">
    <parent link="robot_body"/>
    <child link="right_arm"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <link name="left_arm">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 -1.57"/>
      <geometry>
        <mesh filename="package://warehouse_system/mesh/left_arm_modified.dae"/>
      </geometry>
    </visual>
    <inertial>
      <mass value="0.1"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="0.01" ixy="0" ixz="0" iyy="0.01" iyz="0" izz="0.01"/>
    </inertial>
  </link>

  <joint name="left_arm_joint" type="fixed">
    <parent link="robot_body"/>
    <child link="left_arm"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <!-- ==================== FOOD PLATE ==================== -->
  <link name="food_plate">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 -1.57"/>
      <geometry>
        <mesh filename="package://warehouse_system/mesh/foodplate_modified.dae"/>
      </geometry>
    </visual>
    <inertial>
      <mass value="0.1"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="0.005" ixy="0" ixz="0" iyy="0.005" iyz="0" izz="0.005"/>
    </inertial>
  </link>

  <joint name="food_plate_joint" type="fixed">
    <parent link="right_arm"/>
    <child link="food_plate"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <!-- ==================== WHEELS ==================== -->
  <link name="left_wheel_link">
    <visual>
      <material name="wheel"/>
      <geometry>
        <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
      </geometry>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
      </geometry>
    </collision>
    <xacro:cylinder_inertia m="${wheel_mass}" r="${wheel_radius}" l="${wheel_width}"
                            o_xyz="0 0 0" o_rpy="0 0 0"/>
  </link>

  <joint name="left_wheel_joint" type="continuous">
    <parent link="robot_body"/>
    <child link="left_wheel_link"/>
    <origin xyz="-.07 .178 0" rpy="-1.57 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>

  <link name="right_wheel_link">
    <visual>
      <material name="wheel"/>
      <geometry>
        <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
      </geometry>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
      </geometry>
    </collision>
    <xacro:cylinder_inertia m="${wheel_mass}" r="${wheel_radius}" l="${wheel_width}"
                            o_xyz="0 0 0" o_rpy="0 0 0"/>
  </link>

  <joint name="right_wheel_joint" type="continuous">
    <parent link="robot_body"/>
    <child link="right_wheel_link"/>
    <origin xyz="-.07 -.178 0" rpy="-1.57 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>

  <!-- ==================== CASTER WHEEL ==================== -->
  <link name="caster_wheel_link">
    <visual>
      <material name="caster"/>
      <geometry>
        <sphere radius="${caster_radius}"/>
      </geometry>
    </visual>
    <collision>
      <geometry>
        <sphere radius="${caster_radius}"/>
      </geometry>
    </collision>
    <xacro:sphere_inertia m="${caster_mass}" r="${caster_radius}" o_xyz="0 0 0" o_rpy="0 0 0"/>
  </link>

  <joint name="caster_wheel_joint" type="fixed">
    <parent link="robot_body"/>
    <child link="caster_wheel_link"/>
    <origin xyz="${chassis_length/3.0} 0 ${-caster_radius}" rpy="0 0 0"/>
  </joint>

  <!-- ==================== SENSORS ==================== -->
  <link name="lidar_link">
    <visual>
      <material name="sensor"/>
      <geometry>
        <cylinder radius="0.05" length="0.05"/>
      </geometry>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.05" length="0.05"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.1"/>
      <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
    </inertial>
  </link>

  <joint name="lidar_joint" type="fixed">
    <parent link="robot_body"/>
    <child link="lidar_link"/>
    <origin xyz="${(chassis_length/4)+.13} 0 ${chassis_height-.1}" rpy="0 0 0"/>
  </joint>

  <link name="imu_link">
    <inertial>
      <mass value="0.05"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
    </inertial>
  </link>

  <joint name="imu_joint" type="fixed">
    <parent link="robot_body"/>
    <child link="imu_link"/>
    <origin xyz="0 0 .1" rpy="0 0 0"/>
  </joint>

  <link name="gps_link">
    <visual>
      <geometry>
        <box size="0.05 0.05 0.02"/>
      </geometry>
      <material name="sensor"/>
    </visual>
    <collision>
      <geometry>
        <box size="0.05 0.05 0.02"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.05"/>
      <inertia ixx="0.00001" ixy="0" ixz="0" iyy="0.00001" iyz="0" izz="0.00001"/>
    </inertial>
  </link>

  <joint name="gps_joint" type="fixed">
    <parent link="robot_body"/>
    <child link="gps_link"/>
    <origin xyz="0 0 ${chassis_height+0.5}" rpy="0 0 0"/>
  </joint>

  <!-- ==================== ROS 2 CONTROL ==================== -->
  <ros2_control name="RobotSystem" type="system">
    <hardware>
      <plugin>gz_ros2_control/GazeboSimSystem</plugin>
    </hardware>
    <joint name="left_wheel_joint">
      <command_interface name="velocity"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="right_wheel_joint">
      <command_interface name="velocity"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
  </ros2_control>

  <gazebo>
    <plugin filename="gz_ros2_control-system" name="gz_ros2_control::GazeboSimROS2ControlPlugin">
      <parameters>$(find warehouse_system)/config/ros2_controllers.yaml</parameters>
    </plugin>
  </gazebo>

  <!-- ==================== GAZEBO PROPERTIES ==================== -->
  <gazebo reference="left_wheel_link">
    <mu1>1.0</mu1>
    <mu2>1.0</mu2>
  </gazebo>

  <gazebo reference="right_wheel_link">
    <mu1>1.0</mu1>
    <mu2>1.0</mu2>
    <kp>1000000.0</kp>
    <kd>100.0</kd>
    <minDepth>0.001</minDepth>
    <maxVel>1.0</maxVel>
    <material>Gazebo/Red</material>
  </gazebo>

  <gazebo reference="caster_wheel_link">
    <mu1>0.01</mu1>
    <mu2>0.01</mu2>
    <kp>1000000.0</kp>
    <kd>100.0</kd>
    <minDepth>0.001</minDepth>
    <material>Gazebo/Grey</material>
  </gazebo>

  <!-- ==================== GAZEBO SENSORS ==================== -->
  <gazebo reference="lidar_link">
    <sensor name="lidar_link" type="gpu_lidar">
      <pose relative_to='lidar_link'>0 0 0 0 0 0</pose>
      <update_rate>50</update_rate>
      <topic>scan</topic>
      <gz_frame_id>lidar_link</gz_frame_id>
      <ray>
        <scan>
          <horizontal>
            <samples>640</samples>
            <resolution>1</resolution>
            <min_angle>-1.57</min_angle>
            <max_angle>1.57</max_angle>
          </horizontal>
          <vertical>
            <samples>1</samples>
            <resolution>0.1</resolution>
            <min_angle>0</min_angle>
            <max_angle>0</max_angle>
          </vertical>
        </scan>
        <range>
          <min>0.1</min>
          <max>10.0</max>
        </range>
      </ray>
      <always_on>1</always_on>
      <visualize>true</visualize>
    </sensor>
  </gazebo>

  <gazebo reference="imu_link">
    <sensor name="imu_link" type="imu">
      <always_on>1</always_on>
      <update_rate>100</update_rate>
      <visualize>true</visualize>
      <topic>imu/data</topic>
      <gz_frame_id>imu_link</gz_frame_id>
    </sensor>
  </gazebo>

</robot>
